# Production environment template.
#   cp .env.production.example .env.production
# .env.production is gitignored — never commit real secrets.

APP_NAME=Atrium
APP_ENV=production
# Generate with:
#   docker run --rm atrium-app php artisan key:generate --show
# (or locally: php artisan key:generate --show)
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com

# Host port the web server is published on (compose interpolation).
APP_PORT=80

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Container-friendly logging: everything to stderr, picked up by `docker logs`.
LOG_CHANNEL=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# --- Database (compose service: postgres) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=atrium
DB_USERNAME=atrium
DB_PASSWORD=

# Consumed by the postgres container itself — MUST match DB_* above.
POSTGRES_DB=atrium
POSTGRES_USER=atrium
POSTGRES_PASSWORD=

# --- Redis (compose service: redis) ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Mail ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
