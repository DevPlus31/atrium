includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon
    - phar://phpstan.phar/conf/bleedingEdge.neon

parameters:

    paths:
        - app
        - app-modules
        - bootstrap/app.php
        - config
        - database
        - public
        - routes


    level: max

    excludePaths:
        # Vendor-published files (kept as published; not held to level max).
        - config/horizon.php
        - config/log-viewer.php
        - config/pulse.php
        - database/migrations/2026_07_04_183657_create_pulse_tables.php

    tmpDir: /tmp/phpstan
